APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_FORCE_HTTPS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

PERF_LOG_ENABLED=true
PERF_LOG_SLOW_MS=350
TRAFFIC_ALERT_TOTAL_REQUESTS=1200
TRAFFIC_ALERT_SLOW_REQUESTS=80
TRAFFIC_ALERT_STATUS_429=40
TRAFFIC_ALERT_STATUS_5XX=15
TRAFFIC_ALERT_SLACK_ENABLED=false
OTP_RESEND_COOLDOWN_SECONDS=60

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# DB_CONNECT_TIMEOUT=5

# PostgreSQL backup tools are configured without embedding credentials in commands.
PG_DUMP_PATH=
PG_RESTORE_PATH=
PSQL_PATH=
BACKUP_ENABLED=true
BACKUP_DISK=local
BACKUP_DIRECTORY=backups
BACKUP_TEMPORARY_DIRECTORY=backups/.tmp
BACKUP_DATABASE_CONNECTION=pgsql
BACKUP_TIMEOUT_SECONDS=900
BACKUP_ENCRYPTION_ENABLED=false
BACKUP_ENCRYPTION_KEY=
BACKUP_RESTORE_ALLOWED_ENVIRONMENTS=local,testing
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12
BACKUP_RETENTION_MINIMUM_VALID=1

# Dedicated local-only source used by the Fase 4D restore drill. Never point this at production.
FASE4D_PG_HOST=
FASE4D_PG_PORT=5432
FASE4D_PG_DATABASE=
FASE4D_PG_MAINTENANCE_DATABASE=postgres
FASE4D_PG_USERNAME=
FASE4D_PG_PASSWORD=
FASE4D_PG_DATABASE_PREFIX=siinv_restore_test_

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_HTTP_ONLY=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGINS_PATTERNS=
CORS_SUPPORTS_CREDENTIALS=false
CORS_MAX_AGE=0

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=120
QUEUE_FAILED_DRIVER=database-uuids
EXPORT_QUEUE_CONNECTION=database
EXPORT_QUEUE=exports
EXPORT_STALE_PROCESSING_SECONDS=300

HEALTH_QUEUE_OLDEST_PENDING_WARNING_SECONDS=300
HEALTH_FAILED_JOBS_WARNING=1
HEALTH_EXPORT_PENDING_WARNING_SECONDS=900
HEALTH_EXPORT_STALE_PROCESSING_SECONDS=300
HEALTH_EXPORT_FILE_CHECK_LIMIT=20
HEALTH_SCHEDULER_HEARTBEAT_STALE_SECONDS=180
HEALTH_SCHEDULER_HEARTBEAT_TTL_SECONDS=600
HEALTH_DISK_WARNING_FREE_PERCENT=10
HEALTH_DISK_CRITICAL_FREE_PERCENT=5

CACHE_STORE=database
# CACHE_PREFIX=

# Scheduler memakai default cache store bila nilai ini kosong. Untuk scheduler
# pada beberapa server, gunakan database/shared cache dan aktifkan flag berikut.
SCHEDULER_CACHE_STORE=database
SCHEDULER_MULTI_SERVER=false

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

